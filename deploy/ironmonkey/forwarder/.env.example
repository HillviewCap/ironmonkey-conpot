# Conpot → IronPot forwarder env. Copy to .env on the deploy host.
#
# Two deploy targets:
#   - snakeplskn (test bench): use defaults below
#   - VPS production: override IRONPOT_URL/REDIS_URL with Tailscale hostname
#                     and use SENSOR_ID=sensor-nyc-01-ot

# Bearer token — MUST match HONEYPOT_WEBHOOK_TOKEN in IronPot's env.
# Generate with: openssl rand -hex 32
HONEYPOT_WEBHOOK_TOKEN=

# IronPot ingestion endpoint. snakeplskn test: localhost; VPS: snakeplskn over Tailscale.
IRONPOT_URL=http://localhost:8003

# Redis (DB 0) — used for honeypot:breadcrumb:<source_ip> lookups
REDIS_URL=redis://localhost:6379/0

# Sensor identity emitted on every event.
# Lab prefix routes to stix:honeypot:lab:queue (no MISP side-write, no Neo4j).
# Switch to sensor-nyc-01-ot for VPS production deploy.
SENSOR_ID=sensor-lab-snakeplskn-01-ot

# Conpot JSONL log path inside the forwarder container
CONPOT_LOG=/var/log/conpot/conpot.json

# Retry policy on IronPot POST failures
POST_MAX_RETRIES=3
POST_BACKOFF_SECONDS=2
